{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "vitest"],
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "workbench/src/server.ts", "workbench/src/sampleWorld.ts", "types/**/*.d.ts"],
  "exclude": ["src/_legacy/**", "tests/_legacy/**", "workbench/src/_legacy-server.ts", "node_modules"]
}
