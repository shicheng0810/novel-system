# Optional live LLM provider. Defaults to mock when unset.
NOVEL_LIVE_LLM=mock

# DeepSeek direct API mode.
# NOVEL_LIVE_LLM=deepseek
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Hermes-over-SSH mode.
# NOVEL_LIVE_LLM=hermes
# HERMES_SSH_KEY=/absolute/path/to/private-key
# HERMES_HOST=example.com
# HERMES_USER=ubuntu
# HERMES_MODEL=deepseek-v4-pro
# HERMES_BIN=$HOME/.local/bin/hermes

# Local server / long-run knobs.
PORT=8990
# server 设 saga 才读 longrun 的丰满章节；留空则跑自带内存 demo（占位短章）。
NOVEL_VIEW=saga
NOVEL_SAGA_DIR=saga
# 内容包：modern / freeform / 留空=修仙。
NOVEL_PACK=
# freeform 世界的配置 JSON（由 app/gen-world.ts 或网页 ✦ 生成）。
NOVEL_WORLD_CONFIG=
NOVEL_TARGET=1000
NOVEL_MINLEN=3000
NOVEL_SECTIONS=4
